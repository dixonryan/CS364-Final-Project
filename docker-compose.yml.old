services:
  nginx:
    image: nginx:latest
    container_name: final_web
    ports:
      - "80:80"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./frontend/public:/usr/share/nginx/html:ro
    depends_on:
      - backend
    networks:
      - mynetwork

  backend:
    build: ./backend
    container_name: L27_api
    env_file:
      - .env  # Load environment variables
    volumes:
      - ./backend:/app
    depends_on:
      - db
    networks:
      - mynetwork

  db:
    image: postgres:latest
    container_name: L27_db
    env_file:
      - .env  # load same environment variables
    volumes:
      - pgdata2:/var/lib/postgresql
      - ./init.sql:/docker-entrypoint-initdb.d/init.sql
    networks:
      - mynetwork

volumes:
  pgdata2:

networks:
  mynetwork:
